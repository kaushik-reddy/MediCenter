# MediCenter web — environment variables
# Copy this file to `.env` (or set these in Vercel → Project → Settings → Environment Variables).
# Only VITE_-prefixed vars are exposed to the client bundle.

# Supabase project URL, e.g. https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Supabase anon/public key (safe for the browser; Row Level Security protects the data)
VITE_SUPABASE_ANON_KEY=
